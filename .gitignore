# Ignore everything by default
*

# Allow .gitignore and README
!.gitignore
!README.md

# Allow bashrc
!.bashrc

# Allow XCompose
!.XCompose

# Allow setup scripts
!setup/
!setup/**

# Allow config directories
!.config/
!.config/hypr/
!.config/hypr/**
!.config/tmux/
!.config/tmux/**
!.config/waybar/
!.config/waybar/**
!.config/omarchy/
!.config/omarchy/**
!.config/mako/
!.config/mako/**
!.config/ghostty/
!.config/ghostty/**
!.config/nvim/
!.config/nvim/**
!.config/nvim-chad/
!.config/nvim-chad/**
!.config/starship.toml

# Allow hypr-nav source
!.local/
!.local/src/
!.local/src/hypr-nav/
!.local/src/hypr-nav/**
.local/src/hypr-nav/hypr-nav
.local/src/hypr-nav/test_hypr_nav

# Exclude stock omarchy files (restored by omarchy-theme-set / omarchy-refresh)
.config/hypr/shaders/
.config/omarchy/current/
.config/omarchy/branding/
.config/omarchy/hooks/*.sample
.config/omarchy/themed/*.sample
.config/omarchy/extensions/

# Ignore secrets, caches, and binaries
**/*.secret
**/*.key
**/*.pem
**/*.jpg
**/*.png
**/*.bak.*
